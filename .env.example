# Required: OpenClaw gateway URL
OPENCLAW_GATEWAY=http://127.0.0.1:18789

# Optional: Direct Anthropic API (bypasses gateway)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Display name for the human user
# VEKTOR_USER_NAME=User

# Optional: Server port (default: 8088)
# PORT=8088

# Optional: OpenClaw directory (default: ~/.openclaw)
# OPENCLAW_DIR=~/.openclaw

# Optional: Archive directory for conversation history
# VEKTOR_ARCHIVE_DIR=./data/archive

# Optional: Claude settings path
# CLAUDE_SETTINGS_PATH=~/.claude/settings.json

# Optional: Cross-agent context file path
# VEKTOR_CROSS_AGENT_CONTEXT=./data/memory/cross-agent-context.md
