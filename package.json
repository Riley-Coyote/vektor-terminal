{
  "name": "vektor-terminal-public",
  "version": "1.0.0",
  "description": "⏀ Vektor Terminal — Native interface for OpenClaw agents",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
    "electron": "electron .",
    "electron:dev": "concurrently \"node server.mjs\" \"sleep 2 && electron .\"",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir",
    "postinstall": "electron-builder install-app-deps",
    "capture:electron": "node scripts/capture-electron.mjs",
    "test:electron:snapshots": "playwright test -c playwright.electron.config.mjs",
    "test:electron:update": "playwright test -c playwright.electron.config.mjs --update-snapshots"
  },
  "build": {
    "appId": "com.vektor.terminal.public",
    "productName": "Vektor Public",
    "copyright": "Copyright © 2026",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Vektor",
      "backgroundColor": "#161616",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "electron/**/*",
      "server.mjs",
      "index.html",
      "public/**/*",
      "data/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data/",
        "to": "data/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false
  },
  "keywords": [
    "vektor",
    "terminal",
    "openclaw",
    "ai"
  ],
  "author": "Riley Coyote",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.2",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.58.2"
  }
}
